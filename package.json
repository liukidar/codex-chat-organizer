{
  "name": "codex-chat-organizer",
  "displayName": "Codex Chat Organizer",
  "description": "Browse, search, project, tag, rename, archive, and delete local Codex chats.",
  "version": "0.0.3-rc.14",
  "publisher": "local",
  "private": true,
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liukidar/codex-chat-organizer.git"
  },
  "bugs": {
    "url": "https://github.com/liukidar/codex-chat-organizer/issues"
  },
  "homepage": "https://github.com/liukidar/codex-chat-organizer#readme",
  "keywords": [
    "codex",
    "chat",
    "organizer",
    "vscode"
  ],
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:codexChatOrganizer.threads",
    "onCommand:codexChatOrganizer.refresh",
    "onCommand:codexChatOrganizer.search",
    "onCommand:codexChatOrganizer.clearSearch",
    "onCommand:codexChatOrganizer.createProject",
    "onCommand:codexChatOrganizer.checkCompatibility",
    "onCommand:codexChatOrganizer.showDiagnostics"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Codex Chat Organizer",
      "properties": {
        "codexChatOrganizer.codexHome": {
          "type": "string",
          "default": "",
          "description": "Path to CODEX_HOME. Leave empty to use CODEX_HOME or ~/.codex."
        },
        "codexChatOrganizer.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Python executable used by the helper. Leave empty to auto-detect python3/python."
        },
        "codexChatOrganizer.showArchived": {
          "type": "boolean",
          "default": false,
          "description": "Show archived Codex chats in the organizer."
        },
        "codexChatOrganizer.searchTranscriptContent": {
          "type": "boolean",
          "default": true,
          "description": "When searching, scan transcript JSONL files in addition to thread metadata."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codexChatOrganizer",
          "title": "Codex Chats Explorer",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "codexChatOrganizer": [
        {
          "id": "codexChatOrganizer.threads",
          "name": "",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "codexChatOrganizer.refresh",
        "title": "Codex Chats: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "codexChatOrganizer.search",
        "title": "Codex Chats: Search",
        "icon": "$(search)"
      },
      {
        "command": "codexChatOrganizer.clearSearch",
        "title": "Codex Chats: Clear Search",
        "icon": "$(clear-all)"
      },
      {
        "command": "codexChatOrganizer.createProject",
        "title": "Codex Chats: New Project",
        "icon": "$(new-folder)"
      },
      {
        "command": "codexChatOrganizer.checkCompatibility",
        "title": "Codex Chats: Check Compatibility"
      },
      {
        "command": "codexChatOrganizer.showDiagnostics",
        "title": "Codex Chats: Show Diagnostics",
        "icon": "$(output)"
      }
    ]
  },
  "scripts": {
    "check": "npm run compile && npm run smoke",
    "compile": "tsc -p ./",
    "smoke": "python3 scripts/smoke_test.py",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --no-dependencies --allow-star-activation"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/vscode": "^1.100.0",
    "@vscode/vsce": "^3.2.1",
    "typescript": "^5.7.0"
  }
}
